{
  "name": "ballsdeep",
  "version": "2.0.0",
  "description": "Lightweight numpy/PyTorch-style numerical computing and ML library for Node.js and the browser. Pure JS, zero runtime dependencies.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./nn": "./src/nn/index.js",
    "./optim": "./src/optim/index.js",
    "./data": "./src/data/index.js",
    "./models": "./src/models/index.js"
  },
  "files": [
    "src",
    "README.md",
    "PLAN.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "example:xor": "node examples/xor.js",
    "example:binary": "node examples/binary.js",
    "example:linear": "node examples/linear-regression.js",
    "example:periodic": "node examples/periodic.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ml",
    "machine-learning",
    "deep-learning",
    "neural-network",
    "tensor",
    "autograd",
    "ndarray",
    "numpy",
    "pytorch",
    "browser"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rwrife/BallsDeep.git"
  },
  "author": "Ryan Rife",
  "license": "ISC",
  "homepage": "https://github.com/rwrife/BallsDeep#readme"
}
